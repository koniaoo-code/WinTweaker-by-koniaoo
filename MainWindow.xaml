<Window x:Class="WinTweaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinTweaker - by koniaoo"
        Icon="icon.ico"
        Height="700" Width="1080" MinHeight="480" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Manual"
        Background="{StaticResource BgDarkBrush}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <!-- Minimalist tweak row: name + desc · toggle (state shown by the switch itself) -->
        <DataTemplate x:Key="TweakCardTemplate">
            <Border Style="{StaticResource RowBorder}" Padding="4,0">
                <Grid MinHeight="60">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="8,13" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Desc}" FontSize="12" Margin="0,3,0,0"
                                   Foreground="{StaticResource SecBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleButton Grid.Column="1" Style="{StaticResource Switch}"
                                  Margin="16,0,10,0" VerticalAlignment="Center"
                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                  Click="OnToggleClick"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="264"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar: logo + navigation only (clean) ───────── -->
        <Border Grid.Column="0" Background="{StaticResource BgSidebarBrush}"
                BorderThickness="0,0,1,0" BorderBrush="{StaticResource CardBorderBrush}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="22,24,20,16">
                    <StackPanel x:Name="LogoBox" Orientation="Horizontal" Cursor="Hand"
                                Background="Transparent" MouseLeftButtonUp="OnLogoClick"
                                RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <ScaleTransform/>
                        </StackPanel.RenderTransform>
                        <TextBlock Text="Win" FontFamily="Segoe UI Black" FontSize="25" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Tweaker" FontFamily="Segoe UI Black" FontSize="25"
                                   Foreground="{StaticResource OrangeBrush}"/>
                    </StackPanel>
                    <TextBlock x:Name="ByLbl" Text="by koniaoo" FontSize="11"
                               Foreground="{StaticResource MutedBrush}" Margin="2,3,0,0"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="NavPanel" Margin="12,4,12,14"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── Right content ───────────────────────────────── -->
        <Grid Grid.Column="1" Background="{StaticResource BgPanelBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: big section title -->
            <Grid Grid.Row="0" Margin="30,22,24,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SecTitle" Grid.Column="0" VerticalAlignment="Center"
                           FontSize="23" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
                <TextBlock x:Name="AdminDot" Grid.Column="1" VerticalAlignment="Center" FontSize="11"
                           FontWeight="SemiBold" Foreground="{StaticResource GreenBrush}"/>
            </Grid>

            <ScrollViewer x:Name="ContentScroll" Grid.Row="1" Margin="22,2,18,4"
                          VerticalScrollBarVisibility="Auto"
                          PanningMode="VerticalOnly" PreviewMouseWheel="OnContentWheel">
                <StackPanel x:Name="ContentHost"/>
            </ScrollViewer>

            <!-- Log panel (collapsed by default; toggled from the bottom bar) -->
            <Border x:Name="LogPanel" Grid.Row="2" Background="#FF111114" Height="130"
                    BorderThickness="0,1,0,0" BorderBrush="{StaticResource CardBorderBrush}"
                    Visibility="Collapsed">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="16,6,16,0">
                        <TextBlock x:Name="LogLbl" Text="Лог" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource SecBrush}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="ClearBtn" Content="Очистить" Style="{StaticResource SmallButton}"
                                    Click="OnClearLog"/>
                            <Button Content="✕" Style="{StaticResource SmallButton}" Width="24"
                                    Margin="6,0,0,0" Click="OnCloseLog"/>
                        </StackPanel>
                    </Grid>
                    <TextBox x:Name="LogBox" Background="Transparent" Foreground="#FFAAAAB2"
                             FontFamily="Consolas" FontSize="11" BorderThickness="0" IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto" Margin="16,4,16,8"
                             TextWrapping="NoWrap"/>
                </DockPanel>
            </Border>

            <!-- Bottom bar: search (left) + utilities (right) -->
            <Border Grid.Row="3" Background="{StaticResource BgSidebarBrush}"
                    BorderThickness="0,1,0,0" BorderBrush="{StaticResource CardBorderBrush}">
                <Grid Margin="18,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="SearchHost" Grid.Column="0" Height="36"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Width="380" Background="{StaticResource SearchBrush}" CornerRadius="8"
                            BorderThickness="1" BorderBrush="{StaticResource CardBorderBrush}">
                        <Grid>
                            <!-- Monochrome Fluent search glyph (matches the flat UI, no colored emoji) -->
                            <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Left"
                                       Margin="12,0,0,0" IsHitTestVisible="False"/>
                            <TextBlock x:Name="SearchHint" Foreground="{StaticResource MutedBrush}" FontSize="12.5"
                                       VerticalAlignment="Center" Margin="36,0,0,0" IsHitTestVisible="False"/>
                            <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource PrimaryTextBrush}" CaretBrush="{StaticResource PrimaryTextBrush}" FontSize="12.5"
                                     VerticalContentAlignment="Center" Padding="36,0,8,0"
                                     TextChanged="OnSearch"/>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="RebootBtn" Style="{StaticResource SmallButton}" Height="34"
                                Padding="14,0" Margin="0,0,8,0" Foreground="{StaticResource OrangeBrush}"
                                Click="OnRebootClick" Visibility="Collapsed"/>
                        <Button x:Name="RestartExpBtn" Style="{StaticResource SmallButton}" Height="34"
                                Padding="14,0" Margin="0,0,8,0" Click="OnRestartExplorer"/>
                        <Button x:Name="SettingsBtn" Style="{StaticResource SmallButton}" Height="34"
                                Padding="14,0" Margin="0,0,8,0" Click="OnOpenAbout"/>
                        <Button x:Name="LogToggleBtn" Style="{StaticResource SmallButton}" Height="34"
                                Padding="14,0" Click="OnToggleLog"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
