<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Palette ───────────────────────────────────────── -->
    <Color x:Key="Orange">#FFFF6B00</Color>
    <Color x:Key="OrangeHover">#FFFF8C00</Color>
    <SolidColorBrush x:Key="OrangeBrush"      Color="{StaticResource Orange}"/>
    <SolidColorBrush x:Key="OrangeHoverBrush" Color="{StaticResource OrangeHover}"/>
    <SolidColorBrush x:Key="BgDarkBrush"      Color="#FF0B0B16"/>
    <SolidColorBrush x:Key="BgCardBrush"      Color="#FF17171F"/>
    <SolidColorBrush x:Key="BgCardHoverBrush" Color="#FF20202C"/>
    <SolidColorBrush x:Key="BgSidebarBrush"   Color="#FF0F0F1B"/>
    <SolidColorBrush x:Key="BgPanelBrush"     Color="#FF0D0D18"/>
    <SolidColorBrush x:Key="CardBorderBrush"  Color="#FF282838"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFF4F4F8"/>
    <SolidColorBrush x:Key="SecBrush"         Color="#FF9090A6"/>
    <SolidColorBrush x:Key="MutedBrush"       Color="#FF5A5A70"/>
    <SolidColorBrush x:Key="GreenBrush"       Color="#FF2BD46E"/>
    <SolidColorBrush x:Key="RedBrush"         Color="#FFFF5566"/>
    <SolidColorBrush x:Key="SwitchOffBrush"   Color="#FF2C2C3C"/>
    <SolidColorBrush x:Key="NavHoverBrush"    Color="#FF1A1A28"/>
    <SolidColorBrush x:Key="NavActiveBrush"   Color="#FF221A12"/>
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#FF3A3A4E"/>
    <SolidColorBrush x:Key="ChipBrush"        Color="#FF20202B"/>
    <SolidColorBrush x:Key="ChipHoverBrush"   Color="#FF2C2C3A"/>
    <SolidColorBrush x:Key="SearchBrush"      Color="#FF17171F"/>

    <!-- Vivid sunset accent gradient -->
    <LinearGradientBrush x:Key="OrangeGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFF8A2B" Offset="0"/>
        <GradientStop Color="#FFFF4D6B" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OrangeGradientHover" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFF9B45" Offset="0"/>
        <GradientStop Color="#FFFF6182" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── Switch (ToggleButton) ─────────────────────────── -->
    <Style x:Key="Switch" TargetType="ToggleButton">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="track" CornerRadius="13"
                            Background="{StaticResource SwitchOffBrush}">
                        <Border x:Name="thumb" Width="20" Height="20" CornerRadius="10"
                                Background="#FFCCCCCC"
                                HorizontalAlignment="Left" Margin="3,0,0,0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="thumbT" X="0"/>
                            </Border.RenderTransform>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="track" Property="Background" Value="{StaticResource OrangeGradient}"/>
                            <Setter TargetName="thumb" Property="Background" Value="#FFFFFFFF"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="thumbT"
                                                         Storyboard.TargetProperty="X"
                                                         To="22" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="thumbT"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Tweak card border (hover highlight) ───────────── -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource OrangeBrush}"/>
                <Setter Property="Background" Value="{StaticResource BgCardHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Primary (orange) button ───────────────────────── -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{StaticResource OrangeGradient}" CornerRadius="12">
                        <Border.Effect>
                            <DropShadowEffect Color="#FFFF5A4B" BlurRadius="22" ShadowDepth="0" Opacity="0.45"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource OrangeGradientHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Nav button (sidebar) ──────────────────────────── -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource SecBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="11" Padding="12,0">
                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource NavHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Small flat button (log header) ────────────────── -->
    <Style x:Key="SmallButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource SecBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{StaticResource ChipBrush}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource ChipHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Flat button (recolorable via Background; for tiles/remove) ── -->
    <Style x:Key="FlatButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="{StaticResource OrangeBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Slim modern scrollbar ─────────────────────────── -->
    <Style x:Key="SlimScrollThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="th" CornerRadius="4" Background="{StaticResource ScrollThumbBrush}" Margin="2"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="th" Property="Background" Value="{StaticResource OrangeBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlimScrollRepeat" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SlimScrollRepeat}" Command="ScrollBar.PageUpCommand"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SlimScrollThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SlimScrollRepeat}" Command="ScrollBar.PageDownCommand"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Width" Value="Auto"/>
                            <Setter Property="Height" Value="10"/>
                            <Setter TargetName="PART_Track" Property="Orientation" Value="Horizontal"/>
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
