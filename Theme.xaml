<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Palette (minimalist: near-mono dark + one restrained accent) ── -->
    <Color x:Key="Orange">#FF5B8CF0</Color>
    <Color x:Key="OrangeHover">#FF769FF3</Color>
    <SolidColorBrush x:Key="OrangeBrush"      Color="{DynamicResource Orange}"/>
    <SolidColorBrush x:Key="OrangeHoverBrush" Color="{DynamicResource OrangeHover}"/>
    <SolidColorBrush x:Key="BgDarkBrush"      Color="#FF0F0F11"/>
    <SolidColorBrush x:Key="BgCardBrush"      Color="#FF161618"/>
    <SolidColorBrush x:Key="BgCardHoverBrush" Color="#FF1B1B1E"/>
    <SolidColorBrush x:Key="BgSidebarBrush"   Color="#FF0F0F11"/>
    <SolidColorBrush x:Key="BgPanelBrush"     Color="#FF121214"/>
    <SolidColorBrush x:Key="CardBorderBrush"  Color="#FF222226"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFECECEE"/>
    <SolidColorBrush x:Key="SecBrush"         Color="#FF8C8C94"/>
    <SolidColorBrush x:Key="MutedBrush"       Color="#FF5A5A62"/>
    <SolidColorBrush x:Key="GreenBrush"       Color="#FF4ADE80"/>
    <SolidColorBrush x:Key="RedBrush"         Color="#FFF06C7C"/>
    <SolidColorBrush x:Key="SwitchOffBrush"   Color="#FF2A2A30"/>
    <SolidColorBrush x:Key="NavHoverBrush"    Color="#FF1A1A1E"/>
    <SolidColorBrush x:Key="NavActiveBrush"   Color="#FF1C1C21"/>
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#FF2C2C32"/>
    <SolidColorBrush x:Key="ChipBrush"        Color="#FF1A1A1E"/>
    <SolidColorBrush x:Key="ChipHoverBrush"   Color="#FF232328"/>
    <SolidColorBrush x:Key="SearchBrush"      Color="#FF161618"/>
    <!-- Secondary (non-accent) button: themed so it adapts to light mode too -->
    <SolidColorBrush x:Key="BtnSecondaryBrush"     Color="#FF26262C"/>
    <SolidColorBrush x:Key="BtnSecondaryTextBrush" Color="#FFE6E6EA"/>

    <!-- Flat accent "gradient" (two identical stops = no gradient, stays minimal) -->
    <LinearGradientBrush x:Key="OrangeGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF5B8CF0" Offset="0"/>
        <GradientStop Color="#FF5B8CF0" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OrangeGradientHover" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF769FF3" Offset="0"/>
        <GradientStop Color="#FF769FF3" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── Switch (ToggleButton) ─────────────────────────── -->
    <Style x:Key="Switch" TargetType="ToggleButton">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="track" CornerRadius="13"
                            Background="{DynamicResource SwitchOffBrush}">
                        <Border x:Name="thumb" Width="20" Height="20" CornerRadius="10"
                                Background="#FFCCCCCC"
                                HorizontalAlignment="Left" Margin="3,0,0,0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="thumbT" X="0"/>
                            </Border.RenderTransform>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="track" Property="Background" Value="{DynamicResource OrangeGradient}"/>
                            <Setter TargetName="thumb" Property="Background" Value="#FFFFFFFF"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="thumbT"
                                                         Storyboard.TargetProperty="X"
                                                         To="22" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="thumbT"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Flat tweak row (minimalist: thin separator, subtle hover) ── -->
    <Style x:Key="RowBorder" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Tweak card border (subtle hover, no accent outline) ───────── -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Primary (orange) button ───────────────────────── -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{DynamicResource OrangeGradient}" CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource OrangeGradientHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Nav button (sidebar) ──────────────────────────── -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource SecBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="12,0">
                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource NavHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Small flat button (log header) ────────────────── -->
    <Style x:Key="SmallButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource SecBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{DynamicResource ChipBrush}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource ChipHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Flat button (recolorable via Background; for tiles/remove) ── -->
    <Style x:Key="FlatButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="{DynamicResource OrangeBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Slim modern scrollbar ─────────────────────────── -->
    <Style x:Key="SlimScrollThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="th" CornerRadius="4" Background="{DynamicResource ScrollThumbBrush}" Margin="2"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="th" Property="Background" Value="{DynamicResource OrangeBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlimScrollRepeat" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{DynamicResource SlimScrollRepeat}" Command="ScrollBar.PageUpCommand"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{DynamicResource SlimScrollThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{DynamicResource SlimScrollRepeat}" Command="ScrollBar.PageDownCommand"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Width" Value="Auto"/>
                            <Setter Property="Height" Value="10"/>
                            <Setter TargetName="PART_Track" Property="Orientation" Value="Horizontal"/>
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
