<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Palette ───────────────────────────────────────── -->
    <Color x:Key="Orange">#FFFF6B00</Color>
    <Color x:Key="OrangeHover">#FFFF8C00</Color>
    <SolidColorBrush x:Key="OrangeBrush"      Color="{StaticResource Orange}"/>
    <SolidColorBrush x:Key="OrangeHoverBrush" Color="{StaticResource OrangeHover}"/>
    <SolidColorBrush x:Key="BgDarkBrush"      Color="#FF0F0F0F"/>
    <SolidColorBrush x:Key="BgCardBrush"      Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="BgCardHoverBrush" Color="#FF1F1F1F"/>
    <SolidColorBrush x:Key="BgSidebarBrush"   Color="#FF141414"/>
    <SolidColorBrush x:Key="BgPanelBrush"     Color="#FF161616"/>
    <SolidColorBrush x:Key="CardBorderBrush"  Color="#FF2A2A2A"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="SecBrush"         Color="#FF888888"/>
    <SolidColorBrush x:Key="MutedBrush"       Color="#FF555555"/>
    <SolidColorBrush x:Key="GreenBrush"       Color="#FF00C853"/>
    <SolidColorBrush x:Key="RedBrush"         Color="#FFFF3D00"/>
    <SolidColorBrush x:Key="SwitchOffBrush"   Color="#FF333333"/>
    <SolidColorBrush x:Key="NavHoverBrush"    Color="#FF2A2A2A"/>
    <SolidColorBrush x:Key="NavActiveBrush"   Color="#FF2A1A00"/>

    <!-- ── Switch (ToggleButton) ─────────────────────────── -->
    <Style x:Key="Switch" TargetType="ToggleButton">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="track" CornerRadius="13"
                            Background="{StaticResource SwitchOffBrush}">
                        <Border x:Name="thumb" Width="20" Height="20" CornerRadius="10"
                                Background="#FFCCCCCC"
                                HorizontalAlignment="Left" Margin="3,0,0,0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="thumbT" X="0"/>
                            </Border.RenderTransform>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="track" Property="Background" Value="{StaticResource OrangeBrush}"/>
                            <Setter TargetName="thumb" Property="Background" Value="#FFFFFFFF"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="thumbT"
                                                         Storyboard.TargetProperty="X"
                                                         To="22" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="thumbT"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Tweak card border (hover highlight) ───────────── -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource OrangeBrush}"/>
                <Setter Property="Background" Value="{StaticResource BgCardHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Primary (orange) button ───────────────────────── -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{StaticResource OrangeBrush}" CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource OrangeHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Nav button (sidebar) ──────────────────────────── -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource SecBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,0">
                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource NavHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Small flat button (log header) ────────────────── -->
    <Style x:Key="SmallButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource SecBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="#FF2A2A2A" CornerRadius="5" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#FF383838"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Flat button (recolorable via Background; for tiles/remove) ── -->
    <Style x:Key="FlatButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="{StaticResource OrangeBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
